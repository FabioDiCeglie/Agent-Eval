# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# MCP Gateway (same GATEWAY_JWT_SECRET as .mcp-gateway/.env)
MCP_GATEWAY_URL=http://localhost:8080
GATEWAY_JWT_SECRET=your-secret-at-least-32-chars-long

# Optional MCP auth (Milestone 2.0 — any server)
# MCP_AUTH_TOKEN=          # Bearer token; overrides GATEWAY_JWT_SECRET when set
# MCP_HEADERS={"X-Custom":"value"}   # extra headers (JSON object); Authorization from token/JWT wins
